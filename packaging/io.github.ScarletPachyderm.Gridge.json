{
    "app-id": "io.github.ScarletPachyderm.Gridge",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "gridge",
    "finish-args": [
        "--share=network",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--device=dri",
        "--talk-name=org.freedesktop.Flatpak",
        "--filesystem=home",
        "--filesystem=xdg-data/Steam:rw",
        "--filesystem=~/.steam:rw",
        "--filesystem=~/.var/app:rw"
    ],
    "modules": [
        {
            "name": "gridge",
            "buildsystem": "simple",
            "build-commands": [
                "mkdir -p /app/share/gridge",
                "cp -r *.py vendor launch-browser.sh /app/share/gridge/",
                "install -Dm755 packaging/gridge.sh /app/bin/gridge",
                "install -Dm644 packaging/io.github.ScarletPachyderm.Gridge.desktop /app/share/applications/io.github.ScarletPachyderm.Gridge.desktop",
                "install -Dm644 packaging/io.github.ScarletPachyderm.Gridge.metainfo.xml /app/share/metainfo/io.github.ScarletPachyderm.Gridge.metainfo.xml",
                "install -Dm644 packaging/icons/io.github.ScarletPachyderm.Gridge.svg /app/share/icons/hicolor/scalable/apps/io.github.ScarletPachyderm.Gridge.svg"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/Scarlet-Pachyderm/Gridge.git",
                    "branch": "main"
                }
            ]
        }
    ]
}
